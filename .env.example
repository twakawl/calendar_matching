# Google OAuth 2.0 Web application credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key

# Local development default. For hosted deployments, use durable managed storage.
DATABASE_URL=sqlite:///./calendar.db

# Hosted deployment URL. Fly.io example: https://your-fly-app.fly.dev
# When PUBLIC_BASE_URL is set, the app derives GOOGLE_REDIRECT_URI as:
# ${PUBLIC_BASE_URL}/oauth/callback
PUBLIC_BASE_URL=

# Optional explicit Google OAuth callback. Leave empty for local development or when
# PUBLIC_BASE_URL is enough.
GOOGLE_REDIRECT_URI=

# Fly.io configuration (if deploying there)
FLY_APP_NAME=
FLY_REGION=
FLY_SECRET_KEY=

# Optional direct-run server settings. Fly.io uses the Dockerfile command
# that binds to 0.0.0.0 and uses PORT=8000.
HOST=127.0.0.1
PORT=8000
